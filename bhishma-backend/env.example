# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=bhishma_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-use-a-random-string

# Google OAuth Configuration
# https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID: Web client id (comma-separated to allow multiple audiences).
# Native apps send id_token with aud = that platform's OAuth client — set the matching ids below.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS — comma-separated list of allowed origins for production.
# Leave unset (or "*") for local dev. In production set to your Vercel URL(s):
#   ALLOWED_ORIGINS=https://bhishma-native.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=*

