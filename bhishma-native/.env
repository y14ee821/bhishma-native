#REACT_APP_MQTT_HOST = ws://test.mosquitto.org:8081/mqtt
REACT_APP_MQTT_HOST = wss://test.mosquitto.org:8081/mqtt
#REACT_APP_MQTT_HOST = "wss://broker.emqx.io:8084/mqtt"

# Backend API URL
# Use 10.0.2.2 for Android emulator (maps to host machine's localhost)
# Use localhost for web
EXPO_PUBLIC_API_URL=http://10.125.241.223:8000

# Google OAuth — Android sign-in (Linking + PKCE) uses EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID only.
# In Google Cloud, edit that Android OAuth client: package com.bhishma.bhishmanative, SHA-1 for your keystore,
# and Advanced settings → enable custom URI scheme (required since ~2023 or new clients get invalid_request).
# Web / iOS ids below are for other platforms or backend; optional for Android-only testing.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=226069847114-30umd7dhmic2msim2egg4phh5s027c7a.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=226069847114-30umd7dhmic2msim2egg4phh5s027c7a.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=226069847114-2vmcm16ns72afaeeairhqu9415dtj6pk.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=226069847114-qo78d2d59bvdiaqroi6torvrp6c0nv2s.apps.googleusercontent.com
# Optional: EXPO_PUBLIC_GOOGLE_REDIRECT_URI=com.bhishma.bhishmanative:/oauthredirect
# https://console.cloud.google.com/auth/clients?project=fresh-sanctuary-448004-t2