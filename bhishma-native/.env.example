# Copy to `.env` for local dev. For Vercel, configure these in the
# Project → Settings → Environment Variables UI (Production + Preview).
# Only EXPO_PUBLIC_* (and a few legacy REACT_APP_*) variables are inlined
# into the web bundle at build time.

# MQTT broker (use wss:// in production — browsers block mixed content)
# HiveMQ Cloud Serverless free tier path is /mqtt and the port is 8884
# NOTE: Expo SDK 49+ only inlines vars prefixed with EXPO_PUBLIC_ into the bundle.
EXPO_PUBLIC_MQTT_HOST=wss://<your-cluster-id>.s1.eu.hivemq.cloud:8884/mqtt
EXPO_PUBLIC_MQTT_USERNAME=<your-hivemq-username>
EXPO_PUBLIC_MQTT_PASSWORD=<your-hivemq-password>
# Optional tuning:
# EXPO_PUBLIC_MQTT_KEEPALIVE=60
# EXPO_PUBLIC_MQTT_RECONNECT_PERIOD=5000

# Backend API URL
#  - Local dev:  http://192.168.1.x:8000   (your machine on LAN)
#  - Production: https://<your-render-service>.onrender.com
EXPO_PUBLIC_API_URL=https://bhishma-backend.onrender.com

# Google OAuth client IDs (from Google Cloud Console → APIs & Services → Credentials)
# After deploying, add your Vercel domain to the Web client's
# "Authorized JavaScript origins" and "Authorized redirect URIs".
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
